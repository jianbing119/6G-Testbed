# =============================================================================
# 6G AI Traffic Characterization Testbed - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# =============================================================================
# Required: LLM Provider API Keys
# =============================================================================

# OpenAI API Key (required for chat, image generation, and OpenAI-based agents)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Google API Key (required for Gemini scenarios)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Google Custom Search API Key and Engine ID (required for direct_web_search_google)
# Create at: https://programmablesearchengine.google.com/
# API Key: https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_CX=your-custom-search-engine-id

# DeepSeek API Key (required for DeepSeek scenarios)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Azure OpenAI (required for azure_openai scenarios)
# Deploy a model in Azure OpenAI Studio, then use the deployment name as "model" in scenarios.
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Inference (required for azure_inference scenarios)
# Create a serverless or managed-compute deployment in Azure AI Studio.
AZURE_INFERENCE_ENDPOINT=https://your-model.region.models.ai.azure.com
AZURE_INFERENCE_KEY=your-azure-inference-key

# =============================================================================
# MCP Server API Keys
# =============================================================================

# Brave Search API Key (required for web search in agent scenarios)
# Get your key at: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key-here

# Tavily API Key (alternative search provider)
# Get your key at: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# Exa API Key (neural search)
# Get your key at: https://exa.ai/
EXA_API_KEY=your-exa-api-key-here

# Alpaca Market Data (required for trading/market data agent scenarios)
# Sign up at: https://app.alpaca.markets/signup
# Install: uvx alpaca-mcp-server init
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key


# Spotify (required for music agent scenarios)
# Create an app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret


# =============================================================================
# Communication & Productivity (Phase 5 Scenarios)
# =============================================================================

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# Slack Bot Token
# Create at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Linear API Key
# Get at: https://linear.app/settings/api
LINEAR_API_KEY=your-linear-api-key-here

# =============================================================================
# Cloud Platforms (Phase 5 Scenarios)
# =============================================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Azure Credentials
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# =============================================================================
# Payments & Monitoring (Phase 5 Scenarios)
# =============================================================================

# Stripe API Key (for e-commerce scenarios)
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_your-stripe-key-here

# Sentry Auth Token (for DevOps scenarios)
# Get at: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# =============================================================================
# Testbed Configuration
# =============================================================================

# Enable network emulation (requires --cap-add=NET_ADMIN)
ENABLE_NETEM=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Default LLM model
DEFAULT_MODEL=gpt-5.4

# Maximum concurrent requests
MAX_CONCURRENCY=5

# =============================================================================
# Database Configuration (for Phase 5 scenarios)
# =============================================================================

# PostgreSQL (if using external database)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=testbed
POSTGRES_PASSWORD=testbed_password
POSTGRES_DB=testbed_data

# Redis (if using external cache)
REDIS_HOST=redis
REDIS_PORT=6379

# Chroma (if using external vector DB)
CHROMA_HOST=chroma
CHROMA_PORT=8000


